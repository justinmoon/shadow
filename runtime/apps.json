{
  "schemaVersion": 1,
  "shell": {
    "id": "shell",
    "waylandAppId": "dev.shadow.shell"
  },
  "apps": [
    {
      "id": "counter",
      "model": "typescript",
      "title": "Counter",
      "iconLabel": "01",
      "subtitle": "Counter demo",
      "lifecycleHint": "Shelving keeps the live counter warm until the app exits.",
      "binaryName": "shadow-blitz-demo",
      "waylandAppId": "dev.shadow.counter",
      "windowTitle": "Shadow Counter",
      "runtime": {
        "bundleEnv": "SHADOW_RUNTIME_APP_COUNTER_BUNDLE_PATH",
        "bundleFilename": "runtime-app-counter-bundle.js",
        "inputPath": "runtime/app-counter/app.tsx",
        "cacheDirs": {
          "vm-shell": "build/runtime/app-counter-host",
          "pixel-shell": "build/runtime/pixel-shell-counter",
          "boot-shell-demo": "build/runtime/boot-shell-demo-counter"
        },
        "config": null
      },
      "profiles": [
        "vm-shell",
        "pixel-shell",
        "boot-shell-demo"
      ],
      "ui": {
        "iconColor": "ICON_CYAN"
      }
    },
    {
      "id": "camera",
      "model": "typescript",
      "title": "Camera",
      "iconLabel": "CM",
      "subtitle": "Take and review a photo",
      "lifecycleHint": "The latest captured frame stays visible while the app remains warm.",
      "binaryName": "shadow-blitz-demo",
      "waylandAppId": "dev.shadow.camera",
      "windowTitle": "Shadow Camera",
      "runtime": {
        "bundleEnv": "SHADOW_RUNTIME_APP_CAMERA_BUNDLE_PATH",
        "bundleFilename": "runtime-app-camera-bundle.js",
        "inputPath": "runtime/app-camera/app.tsx",
        "cacheDirs": {
          "vm-shell": "build/runtime/app-camera-host",
          "pixel-shell": "build/runtime/pixel-shell-camera"
        },
        "config": null
      },
      "profiles": [
        "vm-shell",
        "pixel-shell"
      ],
      "ui": {
        "iconColor": "ICON_ORANGE"
      }
    },
    {
      "id": "timeline",
      "model": "typescript",
      "title": "Timeline",
      "iconLabel": "TL",
      "subtitle": "Shared Nostr cache",
      "lifecycleHint": "Shelving keeps the latest cached feed warm. Full restart reloads shared notes.",
      "binaryName": "shadow-blitz-demo",
      "waylandAppId": "dev.shadow.timeline",
      "windowTitle": "Shadow Timeline",
      "runtime": {
        "bundleEnv": "SHADOW_RUNTIME_APP_TIMELINE_BUNDLE_PATH",
        "bundleFilename": "runtime-app-timeline-bundle.js",
        "inputPath": "runtime/app-nostr-timeline/app.tsx",
        "cacheDirs": {
          "vm-shell": "build/runtime/app-nostr-timeline-host",
          "pixel-shell": "build/runtime/pixel-shell-timeline",
          "boot-shell-demo": "build/runtime/boot-shell-demo-timeline"
        },
        "configEnv": "SHADOW_RUNTIME_APP_TIMELINE_CONFIG_JSON",
        "config": {
          "limit": 12,
          "syncOnStart": true
        }
      },
      "profiles": [
        "vm-shell",
        "pixel-shell",
        "boot-shell-demo"
      ],
      "ui": {
        "iconColor": "ICON_ORANGE"
      }
    },
    {
      "id": "podcast",
      "model": "typescript",
      "title": "Podcast",
      "iconLabel": "NS",
      "subtitle": "No Solutions",
      "lifecycleHint": "Shelving keeps the current episode loaded until the player is released.",
      "binaryName": "shadow-blitz-demo",
      "waylandAppId": "dev.shadow.podcast",
      "windowTitle": "No Solutions Player",
      "runtime": {
        "bundleEnv": "SHADOW_RUNTIME_APP_PODCAST_BUNDLE_PATH",
        "bundleFilename": "runtime-app-podcast-bundle.js",
        "inputPath": "runtime/app-podcast-player/app.tsx",
        "cacheDirs": {
          "vm-shell": "build/runtime/app-podcast-player-host",
          "pixel-shell": "build/runtime/pixel-shell-podcast"
        },
        "config": null,
        "assetResolver": "podcast-demo",
        "optionalBundle": true
      },
      "profiles": [
        "vm-shell",
        "pixel-shell"
      ],
      "ui": {
        "iconColor": "ICON_PINK"
      }
    },
    {
      "id": "cashu",
      "model": "typescript",
      "title": "Cashu",
      "iconLabel": "CU",
      "subtitle": "Wallet + Lightning",
      "lifecycleHint": "Shelving keeps your trusted mints and draft flows one tap away.",
      "binaryName": "shadow-blitz-demo",
      "waylandAppId": "dev.shadow.cashu",
      "windowTitle": "Shadow Cashu",
      "runtime": {
        "bundleEnv": "SHADOW_RUNTIME_APP_CASHU_BUNDLE_PATH",
        "bundleFilename": "runtime-app-cashu-bundle.js",
        "inputPath": "runtime/app-cashu-wallet/app.tsx",
        "cacheDirs": {
          "vm-shell": "build/runtime/app-cashu-wallet-host",
          "pixel-shell": "build/runtime/pixel-shell-cashu"
        },
        "config": null
      },
      "profiles": [
        "vm-shell",
        "pixel-shell"
      ],
      "ui": {
        "iconColor": "ICON_GREEN"
      }
    },
    {
      "id": "rust-demo",
      "model": "rust",
      "title": "Rust Demo",
      "iconLabel": "RS",
      "subtitle": "Native Rust window",
      "lifecycleHint": "Native Rust window that proves the binary launch path on VM and rust boot.",
      "binaryName": "shadow-rust-demo",
      "waylandAppId": "dev.shadow.rust-demo",
      "windowTitle": "Shadow Rust Demo",
      "launchEnv": {
        "SHADOW_RUNTIME_CAMERA_ALLOW_MOCK": "1"
      },
      "profiles": [
        "vm-shell",
        "boot-shell-demo"
      ],
      "ui": {
        "iconColor": "ICON_PURPLE"
      }
    },
    {
      "id": "rust-timeline",
      "model": "rust",
      "title": "Rust Nostr",
      "iconLabel": "NR",
      "subtitle": "Shared Nostr engine",
      "lifecycleHint": "Shelving keeps the selected note and cache-backed feed one tap away.",
      "binaryName": "shadow-rust-timeline",
      "waylandAppId": "dev.shadow.rust-timeline",
      "windowTitle": "Shadow Rust Timeline",
      "launchEnv": {
        "SHADOW_RUST_TIMELINE_LIMIT": "18",
        "SHADOW_RUST_TIMELINE_RELAY_URLS": "wss://relay.primal.net/,wss://relay.damus.io/",
        "SHADOW_RUST_TIMELINE_SYNC_ON_START": "1"
      },
      "profiles": [
        "vm-shell"
      ],
      "ui": {
        "iconColor": "ICON_RED"
      }
    }
  ]
}
