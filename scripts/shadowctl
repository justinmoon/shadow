    command, env = script_command("pixel/pixel_root_flash.sh", target=args.target_ref)
    return run_local_script(command, env_assignments=env, dry_run=args.dry_run)


def cmd_ota_sideload(args: argparse.Namespace) -> int:
    command, env = script_command("pixel/pixel_ota_sideload.sh", target=args.target_ref)
    return run_local_script(command, env_assignments=env, dry_run=args.dry_run)


def cmd_run(args: argparse.Namespace) -> int:
    package = args.package
    log_file = f"/var/lib/shadow-ui/log/{package}.log"
    session_env_file = "/var/lib/shadow-ui/shadow-ui-session-env.sh"
    mode = "background" if args.background else "foreground"
    env_assignments = []
    for item in args.env:
        if "=" not in item:
            raise SystemExit(f"shadowctl: expected KEY=VALUE for --env, got {item!r}")
        key, value = item.split("=", 1)
        if not key:
            raise SystemExit(f"shadowctl: invalid empty env key in {item!r}")
        env_assignments.append(f"{key}={shlex.quote(value)}")
    env_prefix = " ".join(env_assignments)
    env_prefix = f"{env_prefix} " if env_prefix else ""
    remote_script = f"""
set -euo pipefail
export XDG_RUNTIME_DIR="${{XDG_RUNTIME_DIR:-/run/user/$(id -u)}}"
session_env_file={shlex.quote(session_env_file)}
package={shlex.quote(package)}
log_file={shlex.quote(log_file)}

load_session_env_from_process() {{
  local session_pid
  session_pid="$(pgrep -o -f 'shadow-compositor' || true)"
  if [[ -z "$session_pid" ]]; then
    echo "shadowctl: could not find a running shadow-compositor" >&2
    exit 1
  fi

  while IFS= read -r -d '' entry; do
    case "$entry" in
      HOME=*|XDG_CACHE_HOME=*|LD_LIBRARY_PATH=*|LIBGL_DRIVERS_PATH=*|XDG_RUNTIME_DIR=*|SHADOW_APP_CLIENT=*|SHADOW_RUNTIME_*=*|WAYLAND_DISPLAY=*|SHADOW_COMPOSITOR_CONTROL=*)
        export "$entry"
        ;;
    esac
  done <"/proc/$session_pid/environ"
}}

if [[ -f "$session_env_file" ]]; then
  source "$session_env_file"
else
  load_session_env_from_process
fi

wayland_socket="$(find "$XDG_RUNTIME_DIR" -maxdepth 1 -type s -name 'wayland-*' -printf '%f\\n' | sort -V | tail -n 1)"
control_socket="$XDG_RUNTIME_DIR/shadow-control.sock"

if [[ -z "$wayland_socket" ]]; then
  echo "shadowctl: no wayland socket found in $XDG_RUNTIME_DIR" >&2
  exit 1
fi

if [[ ! -S "$control_socket" ]]; then
  echo "shadowctl: missing compositor control socket $control_socket" >&2
  exit 1
fi

binary_path="$(command -v "$package" || true)"
if [[ -z "$binary_path" ]]; then
  echo "shadowctl: could not find installed binary $package in the VM" >&2
  exit 1
fi

cmd=(env WAYLAND_DISPLAY="$wayland_socket" SHADOW_COMPOSITOR_CONTROL="$control_socket" {env_prefix}"$binary_path")

echo "mode={mode}"
echo "wayland=$wayland_socket"
echo "control=$control_socket"
if [[ {shlex.quote("1" if args.background else "0")} == "1" ]]; then
  nohup "${{cmd[@]}}" >"$log_file" 2>&1 </dev/null &
  sleep 1
  echo "log=$log_file"
else
  exec "${{cmd[@]}}"
fi
"""

    result = run_remote(remote_script, capture_output=not args.background, check=False)
    return _print_control_result(result)


def cmd_ssh(args: argparse.Namespace) -> int:
    ssh_args = list(args.ssh_args)
    if ssh_args and ssh_args[0] == "--":
        ssh_args = ssh_args[1:]
    command = [str(repo_root() / "scripts" / "vm" / "ui_vm_ssh.sh"), *ssh_args]
    result = subprocess.run(command, check=False)
    return result.returncode


def cmd_root_check(args: argparse.Namespace) -> int:
    if getattr(args, "dry_run", False):
        command, env = script_command("pixel/pixel_root_check.sh", target=args.target_ref)
        return run_local_script(command, env_assignments=env, dry_run=True)

    serial = args.target_ref.serial or args.target_ref.id
    su_user = pixel_root_id(serial)
    if su_user:
        print("root: yes")
        print(f"su_user: {su_user}")
        return 0

    print("root: no")
    print()
    print("If the phone just booted a patched Magisk image, open the Magisk app once.")
    print("If Magisk asks for additional setup or environment fix, accept it and let it reboot.")
    print("Then run:")
    print(f"  sc -t {serial} root-check")
    return 1


def cmd_restore_android(args: argparse.Namespace) -> int:
    command, env = script_command("pixel/pixel_restore_android.sh", target=args.target_ref)
    return run_local_script(command, env_assignments=env, dry_run=args.dry_run)


def add_command(
    subparsers: argparse._SubParsersAction[argparse.ArgumentParser],
    name: str,
    help_text: str,
    func: Any,
    *,
    supported_target_kinds: tuple[str, ...] = (),
    parents: tuple[argparse.ArgumentParser, ...] = (),
) -> argparse.ArgumentParser:
    parser = subparsers.add_parser(
        name,
        help=help_text,
        description=help_text,
        formatter_class=argparse.RawDescriptionHelpFormatter,
        parents=list(parents),
    )
    if supported_target_kinds:
        parser.epilog = f"targets: {', '.join(supported_target_kinds)}"
    parser.set_defaults(func=func, supported_target_kinds=supported_target_kinds)
    return parser


def display_prog() -> str:
    return os.environ.get("SHADOWCTL_PROG") or pathlib.Path(sys.argv[0]).name


def preprocess_argv(argv: list[str]) -> list[str]:
    command_index: int | None = None
    index = 0
    while index < len(argv):
        arg = argv[index]
        if arg in {"-t", "--target"}:
            index += 2
            continue
        if arg.startswith("--target=") or (arg.startswith("-t") and len(arg) > 2):
            index += 1
            continue
        if arg.startswith("-"):
            index += 1
            continue
        command_index = index
        break

    if command_index is None or argv[command_index] != "ssh":
        return argv
    ssh_index = command_index
    passthrough_index = ssh_index + 1
    while passthrough_index < len(argv):
        arg = argv[passthrough_index]
        if arg in {"--", "-h", "--help"}:
            return argv
        if arg in {"-t", "--target"}:
            passthrough_index += 2
            continue
        if arg.startswith("--target=") or (arg.startswith("-t") and len(arg) > 2):
            passthrough_index += 1
            continue
        break
    if passthrough_index >= len(argv):
        return argv
    return [*argv[:passthrough_index], "--", *argv[passthrough_index:]]


def requested_target_kind(requested: str | None, *, default_kind: str) -> str:
    effective = requested or default_kind
    if effective == "desktop":
        return "desktop"
    if effective == "vm":
        return "vm"
    return "pixel"


