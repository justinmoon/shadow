@dataclass(frozen=True)
class TargetRef:
    id: str
    kind: str
    serial: str | None = None


def repo_root() -> pathlib.Path:
    return pathlib.Path(__file__).resolve().parent.parent


def repo_common_root() -> pathlib.Path:
    override = os.environ.get("SHADOW_REPO_COMMON_ROOT")
    if override:
        return pathlib.Path(override).expanduser().resolve()

    result = run_local(["git", "rev-parse", "--git-common-dir"], check=False)
    raw = result.stdout.strip() if result.stdout else ""
    if result.returncode == 0 and raw:
        path = pathlib.Path(raw)
        if not path.is_absolute():
            path = (repo_root() / path).resolve()
        return path.parent

    return repo_root()


def pixel_shared_dir() -> pathlib.Path:
    return repo_common_root() / "build" / "shared" / "pixel"


def lease_dir() -> pathlib.Path:
    return pixel_shared_dir() / "leases"


def lease_lock_file() -> pathlib.Path:
    return lease_dir() / ".lock"


def lease_key(serial: str) -> str:
    return re.sub(r"[^A-Za-z0-9._-]", "_", serial)


def lease_file(serial: str) -> pathlib.Path:
    return lease_dir() / f"{lease_key(serial)}.json"


def first_env(keys: tuple[str, ...]) -> str | None:
    for key in keys:
        value = os.environ.get(key)
        if value:
            return value
    return None


def current_holder_metadata(*, agent: str | None = None, owner: str | None = None) -> dict[str, str]:
    worktree_root = repo_root().resolve()
    worktree_name = worktree_root.name
    host = socket.gethostname()
    user = getpass.getuser()
    agent_value = agent or first_env(LEASE_AGENT_ENV_KEYS)
    owner_value = owner or first_env(LEASE_OWNER_ENV_KEYS)
    holder_id_parts = [user, host, str(worktree_root)]
    if agent_value:
        holder_id_parts.append(agent_value)
    holder_id = "::".join(holder_id_parts)
    holder_label = f"{user}@{host}:{worktree_name}"
    if agent_value:
        holder_label = f"{holder_label}:{agent_value}"
    if not owner_value:
        owner_value = holder_label
    return {
        "holder_id": holder_id,
        "holder_label": holder_label,
        "host": host,
        "user": user,
        "worktree_name": worktree_name,
        "worktree_root": str(worktree_root),
        "agent": agent_value or "",
        "owner": owner_value,
    }


def utc_timestamp(timestamp: float | None = None) -> str:
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(timestamp or time.time()))


def parse_utc_timestamp(value: str) -> float:
    return float(calendar.timegm(time.strptime(value, "%Y-%m-%dT%H:%M:%SZ")))


def parse_duration_secs(value: str) -> int:
    match = LEASE_DURATION_RE.fullmatch(value.strip())
    if match is None:
        raise argparse.ArgumentTypeError(
            "duration must look like 30m, 4h, 2d, or raw seconds"
        )
    amount = int(match.group("value"))
    unit = match.group("unit") or "s"
    multiplier = {"s": 1, "m": 60, "h": 60 * 60, "d": 24 * 60 * 60}[unit]
    return amount * multiplier


def lease_status(record: dict[str, Any], *, now: float | None = None) -> str:
    expires_at_raw = record.get("expires_at")
    if not isinstance(expires_at_raw, str) or not expires_at_raw:
        return "unknown"
    current = now or time.time()
    return "expired" if parse_utc_timestamp(expires_at_raw) <= current else "active"


def lease_remaining_secs(record: dict[str, Any], *, now: float | None = None) -> int | None:
    expires_at_raw = record.get("expires_at")
    if not isinstance(expires_at_raw, str) or not expires_at_raw:
        return None
    remaining = int(parse_utc_timestamp(expires_at_raw) - (now or time.time()))
    return max(remaining, 0)


def lease_owner(record: dict[str, Any]) -> str:
    return str(record.get("owner") or record.get("holder_label") or "")


def lease_summary(record: dict[str, Any]) -> str:
    lane = str(record.get("lane") or "")
    owner = lease_owner(record)
    expires_at = str(record.get("expires_at") or "")
    parts = [owner]
    if lane:
        parts.append(f"lane={lane}")
    if expires_at:
        parts.append(f"until={expires_at}")
    return " ".join(part for part in parts if part)


@contextlib.contextmanager
def locked_lease_registry() -> Any:
    lease_dir().mkdir(parents=True, exist_ok=True)
    with lease_lock_file().open("a+", encoding="utf-8") as fh:
        fcntl.flock(fh.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(fh.fileno(), fcntl.LOCK_UN)


def load_lease_record(serial: str) -> dict[str, Any] | None:
    path = lease_file(serial)
    if not path.exists():
        return None
    return json.loads(path.read_text(encoding="utf-8"))


def atomic_write_json(path: pathlib.Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temp_path: str | None = None
    try:
        with tempfile.NamedTemporaryFile(
            "w",
            encoding="utf-8",
            dir=path.parent,
            prefix=f".{path.name}.",
            delete=False,
        ) as fh:
            json.dump(payload, fh, indent=2, sort_keys=True)
            fh.write("\n")
            temp_path = fh.name
        os.replace(temp_path, path)
    finally:
        if temp_path and os.path.exists(temp_path):
            os.unlink(temp_path)


def lease_record_payload(
    *,
    serial: str,
    lane: str,
    note: str,
    ttl_secs: int,
    agent: str | None,
    owner: str | None,
    lease_id: str | None = None,
) -> dict[str, Any]:
    now = time.time()
    holder = current_holder_metadata(agent=agent, owner=owner)
    return {
        "serial": serial,
        "lease_id": lease_id or uuid.uuid4().hex[:12],
        "status": "active",
        "owner": holder["owner"],
        "holder_id": holder["holder_id"],
        "holder_label": holder["holder_label"],
        "host": holder["host"],
        "user": holder["user"],
        "worktree_name": holder["worktree_name"],
        "worktree_root": holder["worktree_root"],
        "agent": holder["agent"],
        "lane": lane,
        "note": note,
        "pid": os.getpid(),
        "acquired_at": utc_timestamp(now),
        "updated_at": utc_timestamp(now),
        "expires_at": utc_timestamp(now + ttl_secs),
        "ttl_secs": ttl_secs,
    }


def list_lease_records() -> list[dict[str, Any]]:
    records: list[dict[str, Any]] = []
    if not lease_dir().exists():
        return records
    for path in sorted(lease_dir().glob("*.json")):
        try:
            records.append(json.loads(path.read_text(encoding="utf-8")))
        except json.JSONDecodeError as exc:
            records.append(
                {
                    "serial": path.stem,
                    "status": f"invalid: {exc}",
                    "owner": "",
                    "lane": "",
                    "expires_at": "",
                    "lease_id": "",
                }
            )
    return records


def active_leases_by_serial() -> dict[str, dict[str, Any]]:
    leases: dict[str, dict[str, Any]] = {}
    for record in list_lease_records():
        serial = record.get("serial")
        if isinstance(serial, str) and lease_status(record) == "active":
            leases[serial] = record
    return leases


def current_holder_matches(record: dict[str, Any], *, agent: str | None = None) -> bool:
    holder_id = record.get("holder_id")
    if not isinstance(holder_id, str) or not holder_id:
        return False
    return holder_id == current_holder_metadata(agent=agent).get("holder_id")


def print_lease_record(record: dict[str, Any]) -> None:
    print(f"serial={record.get('serial') or ''}")
    print(f"lease_id={record.get('lease_id') or ''}")
    print(f"status={record.get('status') or lease_status(record)}")
    print(f"owner={lease_owner(record)}")
    print(f"holder={record.get('holder_label') or ''}")
    print(f"lane={record.get('lane') or ''}")
    print(f"expires_at={record.get('expires_at') or ''}")
    print(f"remaining_secs={lease_remaining_secs(record) or 0}")
    print(f"worktree={record.get('worktree_name') or ''}")
    print(f"note={record.get('note') or ''}")


def print_lease_records(records: list[dict[str, Any]]) -> None:
    if not records:
        print("no device leases found")
        return
    print("serial\tstatus\towner\tlane\texpires_at\tworktree")
    for record in records:
        print(
            "\t".join(
                [
                    str(record.get("serial") or ""),
                    lease_status(record) if record.get("status") == "active" else str(record.get("status") or ""),
                    lease_owner(record),
                    str(record.get("lane") or ""),
                    str(record.get("expires_at") or ""),
                    str(record.get("worktree_name") or ""),
                ]
            )
        )


def app_manifest_file() -> pathlib.Path:
    override = os.environ.get("SHADOW_APP_METADATA_MANIFEST")
    if override:
        return pathlib.Path(override)
    return repo_root() / "runtime" / "apps.json"


def load_app_manifest() -> dict[str, Any]:
    return json.loads(app_manifest_file().read_text(encoding="utf-8"))


def manifest_shell_id(manifest: dict[str, Any]) -> str:
    return manifest.get("shell", {}).get("id", "shell")


def load_supported_session_apps(
    manifest: dict[str, Any],
    *,
    profile: str,
    model: str | None = None,
) -> tuple[str, ...]:
    shell_id = manifest_shell_id(manifest)
    apps = (
        shell_id,
        *(
            app["id"]
            for app in manifest.get("apps", [])
            if profile in set(app.get("profiles", ()))
            and (model is None or app.get("model") == model)
        ),
    )
    apps = tuple(dict.fromkeys(apps))
    if not apps:
        raise RuntimeError(f"shadowctl: no session apps found in {app_manifest_file()}")
    return apps


def load_manifest_app_binary_names(
    manifest: dict[str, Any],
    *,
    profile: str | None = None,
) -> tuple[str, ...]:
    names = tuple(
        dict.fromkeys(
            app["binaryName"]
            for app in manifest.get("apps", [])
            if isinstance(app.get("binaryName"), str)
            and app["binaryName"]
            and (profile is None or profile in set(app.get("profiles", ())))
        )
    )
    return names


APP_MANIFEST = load_app_manifest()
SHELL_APP_ID = manifest_shell_id(APP_MANIFEST)
VM_APP_BINARY_NAMES = load_manifest_app_binary_names(APP_MANIFEST, profile="vm-shell")
SUPPORTED_SESSION_APPS_BY_TARGET = {
    "pixel": load_supported_session_apps(APP_MANIFEST, profile="pixel-shell", model="typescript"),
    "vm": load_supported_session_apps(APP_MANIFEST, profile="vm-shell"),
}


def supported_session_apps(target_kind: str) -> tuple[str, ...]:
    apps = SUPPORTED_SESSION_APPS_BY_TARGET.get(target_kind)
    if apps is None:
        raise RuntimeError(f"shadowctl: unsupported target kind {target_kind!r}")
    return apps


def format_supported_session_apps(apps: tuple[str, ...]) -> str:
    return ", ".join(f"app={app}" for app in apps)


def state_dir() -> pathlib.Path:
    return repo_root() / ".shadow-vm"


def qmp_socket_path() -> pathlib.Path:
    return state_dir() / "shadow-ui-vm.sock"


def default_vm_ssh_port() -> str:
    digest = hashlib.sha256(str(repo_root()).encode("utf-8")).hexdigest()
    return str(44000 + (int(digest[:8], 16) % 10000))


def ssh_port() -> str:
    return os.environ.get("SHADOW_UI_VM_SSH_PORT", default_vm_ssh_port())


def ssh_base() -> list[str]:
    return [
        "ssh",
        "-p",
        ssh_port(),
        "-o",
        "BatchMode=yes",
        "-o",
        "ConnectTimeout=5",
        "-o",
        "LogLevel=ERROR",
        "-o",
        "ConnectionAttempts=1",
        "-o",
        "StrictHostKeyChecking=no",
        "-o",
        "UserKnownHostsFile=/dev/null",
        "shadow@127.0.0.1",
    ]


def run_local(
    command: list[str],
    *,
    text: bool = True,
    capture_output: bool = True,
    check: bool = True,
) -> subprocess.CompletedProcess[Any]:
    return subprocess.run(
        command,
        text=text,
        capture_output=capture_output,
        check=check,
    )


def run_remote(
    script: str,
    *,
    capture_output: bool = True,
    check: bool = True,
) -> subprocess.CompletedProcess[str]:
    command = ssh_base() + [shlex.join(["bash", "-lc", script])]
    return subprocess.run(command, text=True, capture_output=capture_output, check=check)


def run_local_script(
    command: list[str | pathlib.Path],
    *,
    env_assignments: list[tuple[str, str]] | None = None,
    dry_run: bool = False,
) -> int:
    if dry_run:
        for key, value in env_assignments or []:
            print(f"env={key}={value}")
        print(f"command={shlex.join([str(part) for part in command])}")
        return 0

    env = os.environ.copy()
    for key, value in env_assignments or []:
        env[key] = value
    result = subprocess.run([str(part) for part in command], check=False, env=env)
    return result.returncode


def require_session_app(target: TargetRef, app_id: str) -> None:
    supported_apps = supported_session_apps(target.kind)
    if app_id not in supported_apps:
        supported = format_supported_session_apps(supported_apps)
        raise SystemExit(f"shadowctl: unsupported app {app_id!r}; expected one of {supported}")


def session_start_command(
    target: TargetRef,
    *,
    app_id: str,
    hold: int,
) -> tuple[list[str | pathlib.Path], list[tuple[str, str]]]:
    require_session_app(target, app_id)
    scripts_dir = repo_root() / "scripts"

    if target.kind == "vm":
        command: list[str | pathlib.Path] = [scripts_dir / "vm" / "ui_vm_run.sh"]
        if app_id != SHELL_APP_ID:
            command.extend(["--app", app_id])
        return (command, [])

    serial = target.serial or target.id
    command = [
        scripts_dir / "pixel" / ("pixel_shell_drm_hold.sh" if hold else "pixel_shell_drm.sh")
    ]
    env = [("PIXEL_SERIAL", serial)]
    if app_id != SHELL_APP_ID:
        command.extend(["--app", app_id])
    return (command, env)


def default_session_app_id(target: TargetRef) -> str:
    if target.kind == "pixel":
        return SHELL_APP_ID
    return "podcast"


def session_stop_command(target: TargetRef) -> tuple[list[str | pathlib.Path], list[tuple[str, str]]]:
    scripts_dir = repo_root() / "scripts"
    if target.kind == "vm":
        return ([scripts_dir / "vm" / "ui_vm_stop.sh"], [])

    serial = target.serial or target.id
    return ([scripts_dir / "pixel" / "pixel_restore_android.sh"], [("PIXEL_SERIAL", serial)])


def script_command(
    script_name: str,
    *,
    target: TargetRef | None = None,
) -> tuple[list[str | pathlib.Path], list[tuple[str, str]]]:
    env: list[tuple[str, str]] = []
    if target is not None:
        env.append(("PIXEL_SERIAL", target.serial or target.id))
    return ([repo_root() / "scripts" / script_name], env)


def pixel_ci_command(
    target: TargetRef,
    *,
    run_only: bool = False,
    stage_only: bool = False,
    suite: str,
) -> tuple[list[str | pathlib.Path], list[tuple[str, str]]]:
    if run_only and stage_only:
        raise SystemExit("shadowctl: --stage-only and --run-only are mutually exclusive")
    if suite not in SUPPORTED_PIXEL_CI_SUITES:
        supported = ", ".join(SUPPORTED_PIXEL_CI_SUITES)
        raise SystemExit(f"shadowctl: unsupported Pixel CI suite {suite!r}; expected one of {supported}")

    command: list[str | pathlib.Path] = [repo_root() / "scripts/ci/pixel_ci.sh"]
    if stage_only:
        command.append("--stage-only")
    if run_only:
        command.append("--run-only")
    command.append(suite)
    return command, [("PIXEL_SERIAL", target.serial or target.id)]


def pixel_debug_command(
    target: TargetRef,
    *,
    args: argparse.Namespace,
) -> tuple[list[str | pathlib.Path], list[tuple[str, str]]]:
    tool = args.tool
    if tool == "latency":
        return script_command("debug/pixel_touch_latency_probe.sh", target=target)
    if tool == "scroll-latency":
        return script_command("debug/pixel_shell_scroll_latency_probe.sh", target=target)
    if tool == "runtime-drm":
        return script_command("pixel/pixel_runtime_app_drm.sh", target=target)
    if tool == "runtime-drm-gpu-probe":
        command: list[str | pathlib.Path] = [repo_root() / "scripts/pixel/pixel_runtime_app_drm_gpu_probe.sh"]
        if args.profile:
            command.append(args.profile.removeprefix("profile="))
        return command, [("PIXEL_SERIAL", target.serial or target.id)]
    if tool == "runtime-drm-gpu-matrix":
        return script_command("pixel/pixel_runtime_app_drm_gpu_matrix.sh", target=target)
    if tool == "boot-lab-flash-run":
        command = [repo_root() / "scripts/pixel/pixel_boot_flash_run.sh"]
        if args.image:
            command.extend(["--image", args.image])
        if args.slot:
            command.extend(["--slot", args.slot])
        if args.output:
            command.extend(["--output", args.output])
        if args.wait_ready is not None:
            command.extend(["--wait-ready", str(args.wait_ready)])
        if args.adb_timeout is not None:
            command.extend(["--adb-timeout", str(args.adb_timeout)])
        if args.boot_timeout is not None:
            command.extend(["--boot-timeout", str(args.boot_timeout)])
        if args.success_signal:
            command.extend(["--success-signal", args.success_signal])
        if args.return_timeout is not None:
            command.extend(["--return-timeout", str(args.return_timeout)])
        if args.allow_active_slot:
            command.append("--allow-active-slot")
        if args.recover_after:
            command.append("--recover-after")
        if args.proof_prop:
            command.extend(["--proof-prop", args.proof_prop])
        return command, [("PIXEL_SERIAL", target.serial or target.id)]
    if tool == "boot-lab-oneshot":
        command: list[str | pathlib.Path] = [repo_root() / "scripts/pixel/pixel_boot_oneshot.sh"]
        if args.image:
            command.extend(["--image", args.image])
        if args.output:
            command.extend(["--output", args.output])
        if args.wait_ready is not None:
            command.extend(["--wait-ready", str(args.wait_ready)])
        if args.adb_timeout is not None:
            command.extend(["--adb-timeout", str(args.adb_timeout)])
        if args.boot_timeout is not None:
            command.extend(["--boot-timeout", str(args.boot_timeout)])
        if args.success_signal:
            command.extend(["--success-signal", args.success_signal])
        if args.return_timeout is not None:
            command.extend(["--return-timeout", str(args.return_timeout)])
        if args.skip_collect:
            command.append("--skip-collect")
        if args.recover_traces_after:
            command.append("--recover-traces-after")
        if args.no_wait_boot_completed:
            command.append("--no-wait-boot-completed")
        if args.proof_prop:
            command.extend(["--proof-prop", args.proof_prop])
        return command, [("PIXEL_SERIAL", target.serial or target.id)]
    if tool == "boot-lab-recover-traces":
        command = [repo_root() / "scripts/pixel/pixel_boot_recover_traces.sh"]
        if args.output:
            command.extend(["--output", args.output])
        if args.adb_timeout is not None:
            command.extend(["--adb-timeout", str(args.adb_timeout)])
        if args.boot_timeout is not None:
            command.extend(["--boot-timeout", str(args.boot_timeout)])
        return command, [("PIXEL_SERIAL", target.serial or target.id)]
    supported = ", ".join(SUPPORTED_PIXEL_DEBUG_TOOLS)
    raise SystemExit(f"shadowctl: unsupported Pixel debug tool {tool!r}; expected one of {supported}")


def vm_processes() -> list[str]:
    result = run_local(["pgrep", "-f", "microvm@shadow-ui-vm"], check=False)
    if result.returncode != 0:
        return []
    pids = [pid for pid in result.stdout.split() if pid.strip()]
    if not pids:
        return []
    process_list = run_local(["ps", "-p", ",".join(pids), "-o", "pid=,command="], check=False)
    if process_list.returncode != 0:
        return pids
    port_marker = f"hostfwd=tcp::{ssh_port()}-:22"
    return [
        line
        for line in process_list.stdout.splitlines()
        if line.strip() and port_marker in line
    ]


def vm_artifact_share(process_lines: list[str]) -> str | None:
    pattern = re.compile(r"-fsdev local,id=fs1,path=([^,]+),security_model=none,readonly=false")
    for line in process_lines:
        match = pattern.search(line)
        if match:
            return match.group(1)
    return None


def running_apps(process_lines: list[str]) -> list[str]:
    apps: list[str] = []
    for line in process_lines:
        for name in VM_APP_BINARY_NAMES:
            if f" {name}" in f" {line}" or name in line:
                apps.append(name)
    return sorted(set(apps))


def qmp_request(command: str, arguments: dict[str, Any] | None = None) -> dict[str, Any]:
    qmp_socket = qmp_socket_path()
    if not qmp_socket.exists():
        raise FileNotFoundError(f"shadowctl: missing QMP socket {qmp_socket}")

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.connect(str(qmp_socket))
        greeting = _qmp_read_message(client)
        if "QMP" not in greeting:
            raise RuntimeError(f"shadowctl: unexpected QMP greeting: {greeting!r}")

        _qmp_send_message(client, {"execute": "qmp_capabilities"})
        capabilities = _qmp_read_message(client)
        if "return" not in capabilities:
            raise RuntimeError(f"shadowctl: failed to negotiate QMP capabilities: {capabilities!r}")

        payload: dict[str, Any] = {"execute": command}
        if arguments:
            payload["arguments"] = arguments
        _qmp_send_message(client, payload)
        response = _qmp_read_message(client)
        if "error" in response:
            raise RuntimeError(f"shadowctl: QMP {command} failed: {response['error']}")
        return response


def qmp_available() -> bool:
    try:
        qmp_request("query-status")
        return True
    except (FileNotFoundError, OSError, RuntimeError, json.JSONDecodeError):
        return False


def qmp_send_key(keys: list[str], *, hold_time_ms: int = TEXT_SEND_KEY_HOLD_TIME_MS) -> None:
    if not keys:
        raise RuntimeError("shadowctl: send-key requires at least one qcode")
    qmp_request(
        "send-key",
        {
            "keys": [{"type": "qcode", "data": key} for key in keys],
            "hold-time": hold_time_ms,
        },
    )


def qmp_input_send_key(keys: list[str]) -> None:
    if not keys:
        raise RuntimeError("shadowctl: input-send-event requires at least one qcode")
    events: list[dict[str, Any]] = []
    for key in keys:
        events.append(
            {
                "type": "key",
                "data": {
                    "down": True,
                    "key": {"type": "qcode", "data": key},
                },
            }
        )
    for key in reversed(keys):
        events.append(
            {
                "type": "key",
                "data": {
                    "down": False,
                    "key": {"type": "qcode", "data": key},
                },
            }
        )
    qmp_request("input-send-event", {"events": events})


def qcodes_for_text_char(char: str) -> list[str]:
    if len(char) != 1:
        raise ValueError(f"shadowctl: expected a single character, got {char!r}")
    if "a" <= char <= "z":
        return [char]
    if "0" <= char <= "9":
        return [char]
    if "A" <= char <= "Z":
        return ["shift", char.lower()]

    mapping = {
        " ": ["spc"],
        "\n": ["ret"],
        "\t": ["tab"],
        "-": ["minus"],
        "_": ["shift", "minus"],
        ".": ["dot"],
        ",": ["comma"],
        "/": ["slash"],
        ":": ["shift", "semicolon"],
        ";": ["semicolon"],
    }
    if char in mapping:
        return mapping[char]
    raise ValueError(
        "shadowctl: unsupported text character "
        f"{char!r}; supported characters are ASCII letters, digits, space, newline, tab, "
        "and . , - _ / : ;"
    )


def _qmp_send_message(client: socket.socket, payload: dict[str, Any]) -> None:
    client.sendall(json.dumps(payload).encode("utf-8") + b"\n")


def _qmp_read_message(client: socket.socket) -> dict[str, Any]:
    data = bytearray()
    while True:
        chunk = client.recv(4096)
        if not chunk:
            raise RuntimeError("shadowctl: unexpected EOF from QMP socket")
        data.extend(chunk)
        while b"\n" in data:
            raw_line, _, remainder = data.partition(b"\n")
            data[:] = remainder
            line = raw_line.strip()
            if not line:
                continue
            message = json.loads(line.decode("utf-8"))
            if "event" in message:
                continue
            return message


def vm_status_payload() -> dict[str, Any]:
    local_processes = vm_processes()
    vm_process_names = ("shadow-compositor", *VM_APP_BINARY_NAMES)
    vm_process_names_json = json.dumps(vm_process_names)
    payload: dict[str, Any] = {
        "kind": "vm",
        "target": "vm",
        "local": {
            "state_dir": str(state_dir()),
            "socket_path": str(qmp_socket_path()),
            "socket_exists": qmp_socket_path().exists(),
            "vm_processes": local_processes,
            "artifact_share": vm_artifact_share(local_processes),
        },
    }

    remote_script = r"""
set -euo pipefail
uid="$(id -u shadow 2>/dev/null || id -u)"
runtime_dir="/run/user/${uid}"
session_log="/var/lib/shadow-ui/log/shadow-ui-session.log"
control_socket="${runtime_dir}/shadow-control.sock"
python3 - <<'PY'
import json
import pathlib
import subprocess

runtime_dir = pathlib.Path("/run/user/1000")
session_log = pathlib.Path("/var/lib/shadow-ui/log/shadow-ui-session.log")
control_socket = runtime_dir / "shadow-control.sock"
process_names = __VM_PROCESS_NAMES_JSON__

def cmd(*argv):
    result = subprocess.run(argv, text=True, capture_output=True, check=False)
    return result.returncode, result.stdout, result.stderr

service_props = {}
for line in cmd("systemctl", "show", "shadow-ui-smoke.service", "-p", "ActiveState", "-p", "SubState", "-p", "Result")[1].splitlines():
    if "=" in line:
        key, value = line.split("=", 1)
        service_props[key] = value

process_lines = []
for line in cmd("ps", "-eo", "pid=,comm=,args=")[1].splitlines():
    if not any(name in line for name in process_names):
        continue
    if "python3 - <<'PY'" in line:
        continue
    process_lines.append(line.strip())

log_tail = []
if session_log.exists():
    log_tail = session_log.read_text().splitlines()[-40:]

payload = {
    "service": service_props,
    "runtime_dir": str(runtime_dir),
    "wayland_sockets": sorted(path.name for path in runtime_dir.glob("wayland-*") if path.is_socket()),
    "control_socket_exists": control_socket.exists(),
    "processes": process_lines,
    "session_log_tail": log_tail,
}
print(json.dumps(payload))
PY
"""
    remote_script = remote_script.replace("__VM_PROCESS_NAMES_JSON__", vm_process_names_json)

    remote = run_remote(remote_script, check=False)
    payload["remote"] = {
        "reachable": remote.returncode == 0,
        "returncode": remote.returncode,
        "stderr": remote.stderr.strip(),
    }
    if remote.returncode == 0 and remote.stdout.strip():
        payload["remote"].update(json.loads(remote.stdout))
        remote_processes = payload["remote"].get("processes", [])
        payload["remote"]["running_apps"] = running_apps(remote_processes)
        payload["remote"]["ui_ready"] = bool(
            payload["remote"].get("control_socket_exists")
            and "shadow-composit" in "\n".join(remote_processes)
        )
    return payload


def print_vm_status(payload: dict[str, Any]) -> None:
    local = payload["local"]
    remote = payload["remote"]
    print(f"socket: {'yes' if local['socket_exists'] else 'no'} ({local['socket_path']})")
    if local["vm_processes"]:
        print("vm process:")
        for line in local["vm_processes"]:
            print(f"  {line}")
    else:
        print("vm process: not running")
    if local.get("artifact_share"):
        print(f"vm artifact share: {local['artifact_share']}")

    print(f"remote reachable: {'yes' if remote.get('reachable') else 'no'}")
    if not remote.get("reachable"):
        if remote.get("stderr"):
            print(remote["stderr"])
        return

    service = remote.get("service", {})
    print(
        "shadow-ui-smoke:",
        f"{service.get('ActiveState', 'unknown')}/{service.get('SubState', 'unknown')}",
        f"result={service.get('Result', 'unknown')}",
    )
    print("wayland sockets:", ", ".join(remote.get("wayland_sockets", [])) or "none")
    print("control socket:", "yes" if remote.get("control_socket_exists") else "no")
    if remote.get("running_apps"):
        print("running apps:", ", ".join(remote["running_apps"]))
    print("ui ready:", "yes" if remote.get("ui_ready") else "no")
    print("processes:")
    for line in remote.get("processes", []):
        print(f"  {line}")


def diagnose_vm(payload: dict[str, Any]) -> list[str]:
    issues: list[str] = []
    remote = payload["remote"]
    if not remote.get("reachable"):
        issues.append("VM guest is not reachable over SSH.")
        return issues

    expected_artifact_share = (state_dir() / "runtime-artifacts").resolve()
    artifact_share = payload["local"].get("artifact_share")
    if artifact_share is not None:
        artifact_share_path = pathlib.Path(artifact_share)
        if not artifact_share_path.is_absolute():
            artifact_share_path = (repo_root() / artifact_share_path).resolve()
        if artifact_share_path != expected_artifact_share:
            issues.append(
                f"VM artifact share is {payload['local']['artifact_share']}, not {expected_artifact_share}."
            )

    processes = "\n".join(remote.get("processes", []))
    if not remote.get("control_socket_exists"):
        issues.append("Compositor control socket is missing.")
    if not remote.get("wayland_sockets"):
        issues.append("No Wayland sockets are present in the guest runtime dir.")
    if "shadow-compositor" not in processes and remote.get("ui_ready"):
        issues.append("Control socket exists but shadow-compositor is not visible in the guest process list.")
    return issues


def vm_control_request(command: str) -> subprocess.CompletedProcess[str]:
    script = f"""
set -euo pipefail
export XDG_RUNTIME_DIR="${{XDG_RUNTIME_DIR:-/run/user/$(id -u)}}"
control_socket="$XDG_RUNTIME_DIR/shadow-control.sock"
if [[ ! -S "$control_socket" ]]; then
  echo "shadowctl: missing compositor control socket $control_socket" >&2
  exit 1
fi
export SHADOWCTL_CONTROL_SOCKET="$control_socket"
python3 - <<'PY'
import os
import socket
import sys

path = os.environ["SHADOWCTL_CONTROL_SOCKET"]
timeout = {VM_CONTROL_SOCKET_TIMEOUT_SECS!r}
payload = {command!r}.encode("utf-8") + b"\\n"
with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
    client.settimeout(timeout)
    try:
        client.connect(path)
        client.sendall(payload)
        client.shutdown(socket.SHUT_WR)
        chunks = []
        while True:
            chunk = client.recv(4096)
            if not chunk:
                break
            chunks.append(chunk)
    except TimeoutError:
        print(
            f"shadowctl: compositor control request timed out after {{timeout:g}}s",
            file=sys.stderr,
        )
        raise SystemExit(124)
sys.stdout.write(b"".join(chunks).decode("utf-8"))
PY
"""
    return run_remote(script, capture_output=True, check=False)


def parse_control_state(response: str) -> dict[str, Any]:
    state: dict[str, Any] = {}
    for line in response.splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        state[key] = value

    control_socket = state.get("control_socket") or state.get("socket") or None
    return {
        "focused": state.get("focused") or None,
        "mapped": [item for item in state.get("mapped", "").split(",") if item],
        "launched": [item for item in state.get("launched", "").split(",") if item],
        "shelved": [item for item in state.get("shelved", "").split(",") if item],
        "windows": int(state.get("windows", "0")),
        "transport": state.get("transport") or None,
        "control_socket": control_socket,
        "socket": control_socket,
        "shell_x": int(state["shell_x"]) if "shell_x" in state else None,
        "shell_y": int(state["shell_y"]) if "shell_y" in state else None,
        "shell_width": int(state["shell_width"]) if "shell_width" in state else None,
        "shell_height": int(state["shell_height"]) if "shell_height" in state else None,
        "prompt_active": state.get("prompt_active") == "1",
        "prompt_source_app_id": state.get("prompt_source_app_id") or None,
        "prompt_actions": [item for item in state.get("prompt_actions", "").split(",") if item],
    }


def control_state_for(target: TargetRef) -> dict[str, Any]:
    if target.kind == "vm":
        result = vm_control_request("state")
        if result.returncode == 0:
            state = parse_control_state(result.stdout)
            state["ui_ready"] = True
            state["remote_reachable"] = True
        else:
            state = {
                "focused": None,
                "mapped": [],
                "launched": [],
                "shelved": [],
                "windows": 0,
                "transport": None,
                "control_socket": None,
                "socket": None,
                "ui_ready": False,
                "remote_reachable": False,
                "prompt_active": False,
                "prompt_source_app_id": None,
                "prompt_actions": [],
            }
    else:
        result = pixel_control_request(target.serial or target.id, "state")
        if result.returncode != 0:
            message = (result.stderr or result.stdout or "pixel state request failed").strip()
            raise RuntimeError(message)
        state = parse_control_state(result.stdout)

    state["kind"] = target.kind
    state["target"] = target.id
    return state


def print_control_state(state: dict[str, Any]) -> None:
    print(f"focused={state.get('focused') or ''}")
    print(f"mapped={','.join(state.get('mapped', []))}")
    print(f"launched={','.join(state.get('launched', []))}")
    print(f"shelved={','.join(state.get('shelved', []))}")
    print(f"windows={state.get('windows', 0)}")
    print(f"transport={state.get('transport') or ''}")
    print(f"control_socket={state.get('control_socket') or ''}")
    print(f"socket={state.get('socket') or ''}")
    print(f"prompt_active={'1' if state.get('prompt_active') else '0'}")
    print(f"prompt_source_app_id={state.get('prompt_source_app_id') or ''}")
    print(f"prompt_actions={','.join(state.get('prompt_actions', []))}")
    if state.get("shell_x") is not None and state.get("shell_y") is not None:
        print(f"shell_x={state['shell_x']}")
        print(f"shell_y={state['shell_y']}")
    if state.get("shell_width") is not None and state.get("shell_height") is not None:
        print(f"shell_width={state['shell_width']}")
        print(f"shell_height={state['shell_height']}")


def adb_devices() -> list[dict[str, str]]:
    result = run_local(["adb", "devices"], check=False)
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or "adb devices failed"
        raise RuntimeError(f"shadowctl: {message}")

    devices: list[dict[str, str]] = []
    for raw_line in result.stdout.splitlines()[1:]:
        line = raw_line.strip()
        if not line:
            continue
        parts = line.split()
        serial = parts[0]
        state = parts[1] if len(parts) > 1 else "unknown"
        devices.append(
            {
                "id": serial,
                "kind": "pixel",
                "state": state,
            }
        )
    return devices


def adb_device_map() -> dict[str, str]:
    return {entry["id"]: entry["state"] for entry in adb_devices()}


def resolve_pixel_serial(requested: str | None) -> str:
    devices = adb_device_map()

    if requested:
        if requested not in devices:
            raise SystemExit(
                f"shadowctl: requested target {requested!r} is not connected; run 'sc devices'"
            )
        if devices[requested] != "device":
            raise SystemExit(
                f"shadowctl: target {requested!r} is present via adb but not ready (state={devices[requested]})"
            )
        return requested

    ready = [serial for serial, state in devices.items() if state == "device"]
    if not ready:
        raise SystemExit("shadowctl: no authorized adb device detected")
    if len(ready) > 1:
        joined = "\n  ".join(ready)
        raise SystemExit(
            "shadowctl: multiple adb devices detected; pass --target with one of:\n"
            f"  {joined}"
        )
    return ready[0]


def resolve_target(requested: str | None, *, default_kind: str = "vm") -> TargetRef:
    effective = requested or default_kind
    if effective == "desktop":
        raise SystemExit("shadowctl: target 'desktop' was removed; use 'vm'")
    if effective == "vm":
        return TargetRef(id="vm", kind="vm")
    if effective == "pixel":
        serial = resolve_pixel_serial(None)
        return TargetRef(id=serial, kind="pixel", serial=serial)
    if effective.startswith("pixel:"):
        raise SystemExit("shadowctl: target 'pixel:<serial>' was removed; use the raw adb serial")

    devices = adb_device_map()
    if effective in devices:
        serial = resolve_pixel_serial(effective)
        return TargetRef(id=serial, kind="pixel", serial=serial)

    raise SystemExit(
        f"shadowctl: unknown target {effective!r}; run 'sc devices' for valid ids"
    )


def synthetic_target_for_dry_run(
    requested: str | None,
    *,
    enabled: bool,
    command_name: str,
    default_kind: str,
) -> TargetRef | None:
    if not enabled or command_name not in {
        "ci",
        "debug",
        "ota-sideload",
        "prep-settings",
        "restore-android",
        "root-flash",
        "root-check",
        "root-patch",
        "root-stage",
        "run",
        "stage",
        "stop",
    }:
        return None

    effective = requested or default_kind
    if effective == "desktop":
        raise SystemExit("shadowctl: target 'desktop' was removed; use 'vm'")
    if effective == "vm":
        return TargetRef(id="vm", kind="vm")
    if effective == "pixel":
        return TargetRef(id="pixel", kind="pixel", serial="pixel")
    if effective.startswith("pixel:"):
        raise SystemExit("shadowctl: target 'pixel:<serial>' was removed; use the raw adb serial")
    return TargetRef(id=effective, kind="pixel", serial=effective)


def pixel_runtime_dir() -> str:
    return os.environ.get("PIXEL_RUNTIME_DIR", PIXEL_DEFAULT_RUNTIME_DIR)


def pixel_control_socket_path() -> str:
    return f"{pixel_runtime_dir()}/shadow-control.sock"


def pixel_adb(
    serial: str,
    *argv: str,
    text: bool = True,
    capture_output: bool = True,
    check: bool = True,
) -> subprocess.CompletedProcess[Any]:
    return run_local(
        ["adb", "-s", serial, *argv],
        text=text,
        capture_output=capture_output,
        check=check,
    )


def pixel_su_candidates() -> list[str]:
    primary = os.environ.get("PIXEL_SU_BIN", "/debug_ramdisk/su")
    return [primary, "su"] if primary != "su" else ["su"]


def pixel_root_command(
    serial: str,
    command: str,
    *,
    text: bool = True,
    capture_output: bool = True,
) -> subprocess.CompletedProcess[Any]:
    last_result: subprocess.CompletedProcess[Any] | None = None
    for su_bin in pixel_su_candidates():
        last_result = pixel_adb(
            serial,
            "shell",
            f"{su_bin} 0 sh -c {shlex.quote(command)}",
            text=text,
            capture_output=capture_output,
            check=False,
        )
        if last_result.returncode == 0:
            return last_result
        stderr = ""
        stdout = ""
        if isinstance(last_result.stderr, str):
            stderr = last_result.stderr
        if isinstance(last_result.stdout, str):
            stdout = last_result.stdout
        failure_output = f"{stderr}\n{stdout}"
        if "inaccessible or not found" not in failure_output and "not found" not in failure_output:
            return last_result
    if last_result is None:
        raise RuntimeError("shadowctl: no Pixel root transport candidates configured")
    return last_result


def pixel_root_id(serial: str) -> str | None:
    result = pixel_root_command(serial, "id")
    if result.returncode != 0:
        return None
    output = str(result.stdout).replace("\r", "").strip()
    return output or None


def pixel_root_test(serial: str, command: str) -> bool:
    return pixel_root_command(serial, command, capture_output=True).returncode == 0


def pixel_adb_checked(
    serial: str,
    *argv: str,
    text: bool = True,
    capture_output: bool = True,
) -> subprocess.CompletedProcess[Any]:
    result = pixel_adb(
        serial,
        *argv,
        text=text,
        capture_output=capture_output,
        check=False,
    )
    if result.returncode == 0:
        return result
    stderr = str(result.stderr or "").strip()
    stdout = str(result.stdout or "").strip()
    message = stderr or stdout or f"adb {' '.join(argv)} failed"
    raise RuntimeError(f"shadowctl: {message}")


def pixel_settings_get(serial: str, namespace: str, key: str) -> str:
    result = pixel_adb_checked(serial, "shell", "settings", "get", namespace, key)
    return str(result.stdout).replace("\r", "").strip()


def pixel_control_request(serial: str, command: str) -> subprocess.CompletedProcess[str]:
    control_socket = pixel_control_socket_path()
    phone_script = (
        f"control_socket={shlex.quote(control_socket)}; "
        'if [ ! -S "$control_socket" ]; then '
        'echo "shadowctl: missing compositor control socket $control_socket" >&2; '
        "exit 1; "
        "fi; "
        f"printf '%s\\n' {shlex.quote(command)} | nc -U \"$control_socket\""
    )
    return pixel_adb(serial, "shell", phone_script, check=False)


def pixel_getprops(serial: str) -> dict[str, str]:
    result = pixel_adb(serial, "shell", "getprop", check=False)
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or "adb shell getprop failed"
        raise RuntimeError(f"shadowctl: {message}")
    props: dict[str, str] = {}
    for raw_line in result.stdout.splitlines():
        line = raw_line.replace("\r", "").strip()
        match = GETPROP_RE.match(line)
        if match:
            props[match.group(1)] = match.group(2)
    return props


def pixel_status_payload(target: TargetRef) -> dict[str, Any]:
    serial = target.serial or target.id
    props = pixel_getprops(serial)
    shell_id_result = pixel_adb(serial, "shell", "id", check=False)
    shell_id = shell_id_result.stdout.replace("\r", "").strip() or None
    su_user = pixel_root_id(serial)
    control_socket = pixel_control_socket_path()
    control_socket_exists = False
    state: dict[str, Any] | None = None
    state_error: str | None = None

    if su_user:
        control_socket_exists = (
            pixel_adb(
                serial,
                "shell",
                f"[ -S {shlex.quote(control_socket)} ]",
                capture_output=True,
                check=False,
            ).returncode
            == 0
        )
        if control_socket_exists:
            state_result = pixel_control_request(serial, "state")
            if state_result.returncode == 0:
                state = parse_control_state(state_result.stdout)
            else:
                state_error = (state_result.stderr or state_result.stdout).strip()

    return {
        "kind": "pixel",
        "target": target.id,
        "serial": serial,
        "adb_state": "device",
        "model": props.get("ro.product.model"),
        "device": props.get("ro.product.device"),
        "fingerprint": props.get("ro.build.fingerprint"),
        "cpu_abi": props.get("ro.product.cpu.abi"),
        "boot_completed": props.get("sys.boot_completed") or props.get("dev.bootcomplete") or "0",
        "slot_suffix": props.get("ro.boot.slot_suffix") or "unknown",
        "flash_locked": props.get("ro.boot.flash.locked") or "unknown",
        "verified_boot_state": props.get("ro.boot.verifiedbootstate") or "unknown",
        "debuggable": props.get("ro.debuggable") or "unknown",
        "shell_user": shell_id,
        "su_available": su_user is not None,
        "su_user": su_user,
        "control_socket": control_socket,
        "control_socket_exists": control_socket_exists,
        "ui_ready": state is not None,
        "state": state,
        "state_error": state_error,
    }


def print_pixel_status(payload: dict[str, Any]) -> None:
    print(f"serial: {payload['serial']}")
    print(f"model: {payload.get('model') or 'unknown'}")
    print(f"device: {payload.get('device') or 'unknown'}")
    print(f"fingerprint: {payload.get('fingerprint') or 'unknown'}")
    print(f"cpu_abi: {payload.get('cpu_abi') or 'unknown'}")
    print(f"boot_completed: {payload.get('boot_completed') or '0'}")
    print(f"slot_suffix: {payload.get('slot_suffix') or 'unknown'}")
    print(f"flash_locked: {payload.get('flash_locked') or 'unknown'}")
    print(f"verified_boot_state: {payload.get('verified_boot_state') or 'unknown'}")
    print(f"debuggable: {payload.get('debuggable') or 'unknown'}")
    print(f"shell_user: {payload.get('shell_user') or 'unknown'}")
    print(f"su_available: {'yes' if payload.get('su_available') else 'no'}")
    if payload.get("su_user"):
        print(f"su_user: {payload['su_user']}")
    print(
        f"control socket: {'yes' if payload.get('control_socket_exists') else 'no'} "
        f"({payload.get('control_socket')})"
    )
    print(f"ui ready: {'yes' if payload.get('ui_ready') else 'no'}")
    state = payload.get("state")
    if state:
        print(f"focused: {state.get('focused') or ''}")
        print("mapped:", ", ".join(state.get("mapped", [])) or "none")
        print("shelved:", ", ".join(state.get("shelved", [])) or "none")
    elif payload.get("state_error"):
        print(f"state error: {payload['state_error']}")


def diagnose_pixel(payload: dict[str, Any]) -> list[str]:
    issues: list[str] = []
    if payload.get("boot_completed") != "1":
        issues.append("Android boot has not completed yet.")
    if not payload.get("su_available"):
        issues.append("Root shell is unavailable.")
    if payload.get("su_available") and not payload.get("control_socket_exists"):
        issues.append("Shadow shell control socket is not live on the device.")
    if payload.get("control_socket_exists") and not payload.get("ui_ready"):
        issues.append("Control socket exists but the shell did not answer a state request.")
    return issues


def device_entries() -> list[dict[str, Any]]:
    entries: list[dict[str, Any]] = []
    leases = active_leases_by_serial()
    local_processes = vm_processes()
    if local_processes or qmp_available():
        entries.append(
            {
                "id": "vm",
                "kind": "vm",
                "state": "running",
            }
        )
    try:
        entries.extend(adb_devices())
    except (FileNotFoundError, RuntimeError) as exc:
        message = str(exc).removeprefix("shadowctl: ")
        entries.append({"id": "adb", "kind": "adb", "state": f"error: {message}"})

    for entry in entries:
        if entry.get("kind") != "pixel":
            continue
        record = leases.get(str(entry.get("id") or ""))
        if record is None:
            entry["lease"] = None
            continue
        entry["lease"] = {
            "owner": lease_owner(record),
            "lane": str(record.get("lane") or ""),
            "expires_at": str(record.get("expires_at") or ""),
            "summary": lease_summary(record),
        }
    return entries


def print_device_entries(entries: list[dict[str, Any]]) -> None:
    if not entries:
        print("no running targets found")
        return
    print("id\tkind\tstate\tlease")
    for entry in entries:
        lease = entry.get("lease")
        lease_summary_value = ""
        if isinstance(lease, dict):
            lease_summary_value = str(lease.get("summary") or "")
        print(f"{entry['id']}\t{entry['kind']}\t{entry['state']}\t{lease_summary_value}")


def control_request_for(target: TargetRef, command: str) -> subprocess.CompletedProcess[str]:
    if target.kind == "vm":
        return vm_control_request(command)
    serial = target.serial or target.id
    return pixel_control_request(serial, command)


def clear_remote_frame_path(target: TargetRef, remote_path: str) -> None:
    quoted_path = shlex.quote(remote_path)
    if target.kind == "vm":
        run_remote(f"rm -f {quoted_path}", check=False)
        return

    serial = target.serial or target.id
    pixel_root_command(serial, f"rm -f {quoted_path}")


def remote_frame_available(target: TargetRef, remote_path: str) -> bool:
    quoted_path = shlex.quote(remote_path)
    if target.kind == "vm":
        return run_remote(f"test -s {quoted_path}", check=False).returncode == 0

    serial = target.serial or target.id
    return pixel_root_test(serial, f"test -s {quoted_path}")


def wait_for_remote_frame(target: TargetRef, remote_path: str) -> bool:
    deadline = time.monotonic() + FRAME_CAPTURE_WAIT_TIMEOUT_SECS
    while True:
        if remote_frame_available(target, remote_path):
            return True
        if time.monotonic() >= deadline:
            return False
        time.sleep(FRAME_CAPTURE_WAIT_INTERVAL_SECS)


def lease_conflict_message(serial: str, record: dict[str, Any]) -> str:
    owner = lease_owner(record) or "unknown"
    lane = str(record.get("lane") or "")
    expires_at = str(record.get("expires_at") or "")
    lane_segment = f" lane={lane}" if lane else ""
    expires_segment = f" expires_at={expires_at}" if expires_at else ""
    return (
        f"shadowctl: active lease on {serial} held by {owner}{lane_segment}{expires_segment}; "
        "run `sc lease show <serial>`, use `--force` to replace it, "
        "or set `SHADOW_DEVICE_LEASE_FORCE=1` to bypass the guard"
    )


def cmd_lease_list(args: argparse.Namespace) -> int:
    records = list_lease_records()
    if args.json:
        payload = []
        for record in records:
            item = dict(record)
            item["status"] = lease_status(record) if record.get("status") == "active" else record.get("status")
            item["remaining_secs"] = lease_remaining_secs(record)
            payload.append(item)
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print_lease_records(records)
    return 0


def cmd_lease_show(args: argparse.Namespace) -> int:
    record = load_lease_record(args.serial)
    if record is None:
        payload = {"serial": args.serial, "leased": False}
        if args.json:
            print(json.dumps(payload, indent=2, sort_keys=True))
        else:
            print(f"serial={args.serial}")
            print("leased=0")
        return 0

    payload = dict(record)
    payload["leased"] = lease_status(record) == "active"
    payload["status"] = lease_status(record) if record.get("status") == "active" else record.get("status")
    payload["remaining_secs"] = lease_remaining_secs(record)
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print_lease_record(payload)
    return 0


def cmd_lease_acquire(args: argparse.Namespace) -> int:
    with locked_lease_registry():
        existing = load_lease_record(args.serial)
        existing_active = existing is not None and lease_status(existing) == "active"
        if existing_active and not current_holder_matches(existing, agent=args.agent) and not args.force:
            raise SystemExit(lease_conflict_message(args.serial, existing))

        if existing_active and current_holder_matches(existing, agent=args.agent):
            action = "renewed"
            lease_id = str(existing.get("lease_id") or "")
        elif existing is not None and args.force:
            action = "replaced"
            lease_id = None
        else:
            action = "acquired"
            lease_id = None

        record = lease_record_payload(
            serial=args.serial,
            lane=args.lane,
            note=args.note,
            ttl_secs=args.ttl,
            agent=args.agent,
            owner=args.owner,
            lease_id=lease_id,
        )
        atomic_write_json(lease_file(args.serial), record)

    payload = dict(record)
    payload["action"] = action
    payload["remaining_secs"] = lease_remaining_secs(record)
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print_lease_record(payload)
        print(f"action={action}")
    return 0


def cmd_lease_renew(args: argparse.Namespace) -> int:
    with locked_lease_registry():
        existing = load_lease_record(args.serial)
        if existing is None:
            raise SystemExit(f"shadowctl: no existing lease for {args.serial}")
        if not current_holder_matches(existing, agent=args.agent) and not args.force:
            raise SystemExit(lease_conflict_message(args.serial, existing))

        record = lease_record_payload(
            serial=args.serial,
            lane=args.lane or str(existing.get("lane") or ""),
            note=args.note if args.note else str(existing.get("note") or ""),
            ttl_secs=args.ttl,
            agent=args.agent,
            owner=args.owner or lease_owner(existing),
            lease_id=str(existing.get("lease_id") or ""),
        )
        atomic_write_json(lease_file(args.serial), record)

    payload = dict(record)
    payload["action"] = "renewed"
    payload["remaining_secs"] = lease_remaining_secs(record)
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print_lease_record(payload)
        print("action=renewed")
    return 0


def cmd_lease_release(args: argparse.Namespace) -> int:
    with locked_lease_registry():
        existing = load_lease_record(args.serial)
        if existing is None:
            raise SystemExit(f"shadowctl: no existing lease for {args.serial}")
        if not current_holder_matches(existing, agent=args.agent) and not args.force:
            raise SystemExit(lease_conflict_message(args.serial, existing))
        lease_file(args.serial).unlink(missing_ok=True)

    payload = dict(existing)
    payload["action"] = "released"
    payload["status"] = "released"
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print_lease_record(payload)
        print("action=released")
    return 0


def cmd_lease_check(args: argparse.Namespace) -> int:
    if os.environ.get("SHADOW_DEVICE_LEASE_FORCE") in {"1", "true", "yes"}:
        return 0

    record = load_lease_record(args.serial)
    if record is None or lease_status(record) != "active":
        return 0
    if current_holder_matches(record, agent=args.agent):
        return 0
    raise SystemExit(lease_conflict_message(args.serial, record))


def cmd_devices(args: argparse.Namespace) -> int:
    entries = device_entries()
    if args.json:
        print(json.dumps(entries, indent=2, sort_keys=True))
    else:
        print_device_entries(entries)
    return 0


def cmd_status(args: argparse.Namespace) -> int:
    target = args.target_ref
    payload = vm_status_payload() if target.kind == "vm" else pixel_status_payload(target)
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        if target.kind == "vm":
            print_vm_status(payload)
        else:
            print_pixel_status(payload)
    return 0


def cmd_logs(args: argparse.Namespace) -> int:
    target = args.target_ref
    if target.kind == "vm":
        script = f"tail -n {args.lines} /var/lib/shadow-ui/log/shadow-ui-session.log"
        result = run_remote(script, capture_output=False, check=False)
        return result.returncode
    serial = target.serial or target.id
    result = pixel_adb(serial, "logcat", "-d", "-t", str(args.lines), capture_output=False, check=False)
    return result.returncode


def cmd_journal(args: argparse.Namespace) -> int:
    script = f"journalctl -b -u greetd.service -u shadow-ui-smoke.service --no-pager -n {args.lines}"
    result = run_remote(script, capture_output=False, check=False)
    return result.returncode


def cmd_doctor(args: argparse.Namespace) -> int:
    target = args.target_ref
    if target.kind == "vm":
        payload = vm_status_payload()
        issues = diagnose_vm(payload)
        if args.json:
            print(json.dumps({"status": payload, "issues": issues}, indent=2, sort_keys=True))
        else:
            print_vm_status(payload)
            print()
            if issues:
                print("diagnosis:")
                for issue in issues:
                    print(f"  - {issue}")
            else:
                print("diagnosis: no obvious issues detected")
        return 0

    payload = pixel_status_payload(target)
    issues = diagnose_pixel(payload)
    if args.json:
        print(json.dumps({"status": payload, "issues": issues}, indent=2, sort_keys=True))
    else:
        print_pixel_status(payload)
        print()
        if issues:
            print("diagnosis:")
            for issue in issues:
                print(f"  - {issue}")
        else:
            print("diagnosis: no obvious issues detected")
    return 0


def resolve_output_path(target: TargetRef, output: str | None) -> pathlib.Path:
    if output:
        path = pathlib.Path(output).expanduser()
        if not path.is_absolute():
            path = repo_root() / path
        return path
    if target.kind == "vm":
        return repo_root() / "build/ui-vm/shadow-ui-vm.ppm"
    serial = target.serial or target.id
    return repo_root() / f"build/pixel/{serial}-screenshot.png"


def resolve_frame_output_path(target: TargetRef, output: str | None) -> pathlib.Path:
    if output:
        path = pathlib.Path(output).expanduser()
        if not path.is_absolute():
            path = repo_root() / path
        return path
    if target.kind == "vm":
        return repo_root() / "build/ui-vm/shadow-frame.ppm"
    serial = target.serial or target.id
    return repo_root() / f"build/pixel/{serial}-shadow-frame.ppm"


def default_frame_remote_path(target: TargetRef) -> str:
    if target.kind == "vm":
        return "/tmp/shadow-frame.ppm"
    return os.environ.get("PIXEL_FRAME_PATH", "/data/local/tmp/shadow-frame.ppm")


def cmd_screenshot(args: argparse.Namespace) -> int:
    target = args.target_ref
    output = resolve_output_path(target, args.output)
    output.parent.mkdir(parents=True, exist_ok=True)

    if target.kind == "vm":
        qmp_request("screendump", {"filename": str(output)})
        print(output)
        return 0

    serial = target.serial or target.id
    result = pixel_adb(serial, "exec-out", "screencap", "-p", text=False, check=False)
    if result.returncode != 0:
        if result.stderr:
            sys.stderr.write(result.stderr.decode("utf-8", errors="replace"))
        return result.returncode
    output.write_bytes(result.stdout)
    print(output)
    return 0


def _control_error_text(
    result: subprocess.CompletedProcess[str], *, require_ok: bool = False
) -> str | None:
    if result.returncode != 0:
        return (result.stderr or result.stdout or f"control request exited {result.returncode}").strip()
    stdout = result.stdout or ""
    if stdout.startswith("error="):
        return stdout.strip()
    if require_ok and "ok" not in stdout.splitlines():
        return "shadowctl: snapshot request did not return ok"
    return None


def cmd_frame(args: argparse.Namespace) -> int:
    target = args.target_ref
    output = resolve_frame_output_path(target, args.output)
    output.parent.mkdir(parents=True, exist_ok=True)
    remote_path = args.remote_path or default_frame_remote_path(target)

    clear_remote_frame_path(target, remote_path)
    result = control_request_for(target, f"snapshot {remote_path}")
    if error_text := _control_error_text(result, require_ok=True):
        print(error_text, file=sys.stderr)
        return result.returncode or 1
    if not wait_for_remote_frame(target, remote_path):
        timeout = f"{FRAME_CAPTURE_WAIT_TIMEOUT_SECS:.1f}".rstrip("0").rstrip(".")
        print(
            f"shadowctl: snapshot {remote_path} did not materialize within {timeout}s",
            file=sys.stderr,
        )
        return 1

    if target.kind == "vm":
        cat_result = run_local(
            ssh_base() + ["cat", remote_path],
            text=False,
            capture_output=True,
            check=False,
        )
        if cat_result.returncode != 0:
            stderr = cat_result.stderr.decode("utf-8", errors="replace")
            stdout = cat_result.stdout.decode("utf-8", errors="replace")
            print((stderr or stdout or "shadowctl: failed to read remote frame").strip(), file=sys.stderr)
            return cat_result.returncode
        output.write_bytes(cat_result.stdout)
        print(output)
        return 0

    serial = target.serial or target.id
    pull = pixel_adb(serial, "pull", remote_path, str(output), check=False)
    if pull.returncode != 0:
        print((pull.stderr or pull.stdout or "shadowctl: failed to pull frame").strip(), file=sys.stderr)
        return pull.returncode
    print(output)
    return 0


def cmd_state(args: argparse.Namespace) -> int:
    try:
        state = control_state_for(args.target_ref)
    except RuntimeError as error:
        print(str(error), file=sys.stderr)
        return 1
    if args.json:
        print(json.dumps(state, indent=2, sort_keys=True))
    else:
        print_control_state(state)
    return 0


def _print_control_result(result: subprocess.CompletedProcess[str]) -> int:
    stdout = result.stdout or ""
    if result.stdout:
        print(result.stdout, end="")
    if result.stderr:
        print(result.stderr, end="", file=sys.stderr)
    if result.returncode != 0:
        return result.returncode
    return 1 if stdout.startswith("error=") else 0


def _response_fields(stdout: str) -> dict[str, str]:
    fields: dict[str, str] = {}
    for line in stdout.splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        fields[key.strip()] = value.strip()
    return fields


def cmd_open(args: argparse.Namespace) -> int:
    require_session_app(args.target_ref, args.app_id)
    return _print_control_result(control_request_for(args.target_ref, f"launch {args.app_id}"))


def cmd_home(args: argparse.Namespace) -> int:
    return _print_control_result(control_request_for(args.target_ref, "home"))


def cmd_switcher(args: argparse.Namespace) -> int:
    return _print_control_result(control_request_for(args.target_ref, "switcher"))


def cmd_tap(args: argparse.Namespace) -> int:
    return _print_control_result(control_request_for(args.target_ref, f"tap {args.x} {args.y}"))


def cmd_text(args: argparse.Namespace) -> int:
    try:
        state = control_state_for(args.target_ref)
        if state.get("prompt_active") and not args.allow_prompt:
            raise RuntimeError(
                "shadowctl: refusing to type while a system prompt is active; pass --allow-prompt to override"
            )
        if not state.get("focused") and not args.allow_unfocused:
            raise RuntimeError(
                "shadowctl: refusing to type without a focused app; pass --allow-unfocused to override"
            )
        for char in args.text:
            qmp_input_send_key(qcodes_for_text_char(char))
            time.sleep(args.interval_ms / 1000.0)
    except (RuntimeError, ValueError) as error:
        print(str(error), file=sys.stderr)
        return 1
    return 0


def cmd_media(args: argparse.Namespace) -> int:
    result = control_request_for(args.target_ref, f"media {args.action}")
    status = _print_control_result(result)
    if status != 0:
        return status

    handled = _response_fields(result.stdout or "").get("handled")
    if handled == "0":
        print("shadowctl: media action was not handled", file=sys.stderr)
        return 1
    return 0


def cmd_prompt(args: argparse.Namespace) -> int:
    result = control_request_for(args.target_ref, f"prompt {args.action_id}")
    status = _print_control_result(result)
    if status != 0:
        return status

    fields = _response_fields(result.stdout or "")
    if fields.get("handled") == "0":
        reason = fields.get("reason") or "prompt action was not handled"
        print(f"shadowctl: {reason}", file=sys.stderr)
        return 1
    return 0


def cmd_wait_ready(args: argparse.Namespace) -> int:
    target = args.target_ref
    deadline = time.time() + args.timeout

    if target.kind == "vm":
        while time.time() < deadline:
            result = vm_control_request("state")
            if result.returncode == 0:
                if args.json:
                    print(json.dumps(control_state_for(target), indent=2, sort_keys=True))
                else:
                    print("ui ready")
                return 0
            time.sleep(args.interval)
    else:
        serial = target.serial or target.id
        while time.time() < deadline:
            if pixel_control_request(serial, "state").returncode == 0:
                if args.json:
                    print(json.dumps(pixel_status_payload(target), indent=2, sort_keys=True))
                else:
                    print("ui ready")
                return 0
            time.sleep(args.interval)

    print("shadowctl: timed out waiting for UI readiness", file=sys.stderr)
    return 1


