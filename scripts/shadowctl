def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(preprocess_argv(list(sys.argv[1:] if argv is None else argv)))
    global_target = getattr(args, "global_target", None)
    local_target = getattr(args, "target", None)
    if global_target and local_target and global_target != local_target:
        print(
            f"shadowctl: conflicting targets: global {global_target!r}, command {local_target!r}",
            file=sys.stderr,
        )
        return 2
    requested_target = local_target or global_target
    supported_target_kinds = tuple(getattr(args, "supported_target_kinds", ()))

    if supported_target_kinds:
        default_kind = supported_target_kinds[0] if len(supported_target_kinds) == 1 else "vm"
        target_kind = requested_target_kind(requested_target, default_kind=default_kind)
        if target_kind == "desktop":
            print("shadowctl: target 'desktop' was removed; use 'vm'", file=sys.stderr)
            return 1
        if target_kind not in supported_target_kinds:
            supported = ", ".join(supported_target_kinds)
            got = requested_target or default_kind
            print(
                f"shadowctl: {args.command} supports targets: {supported}; got {got} ({target_kind})",
                file=sys.stderr,
            )
            return 2
        target_ref = synthetic_target_for_dry_run(
            requested_target,
            enabled=bool(getattr(args, "dry_run", False)),
            command_name=args.command,
            default_kind=default_kind,
        )
        if target_ref is None:
            target_ref = resolve_target(requested_target, default_kind=default_kind)
        if target_ref.kind not in supported_target_kinds:
            supported = ", ".join(supported_target_kinds)
            print(
                f"shadowctl: {args.command} supports targets: {supported}; "
                f"got {target_ref.id} ({target_ref.kind})",
                file=sys.stderr,
            )
            return 2
        args.target_ref = target_ref
    elif requested_target is not None:
        print(f"shadowctl: {args.command} does not accept --target", file=sys.stderr)
        return 2

    return args.func(args)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except (FileNotFoundError, RuntimeError) as exc:
        print(exc, file=sys.stderr)
        raise SystemExit(1)
    except KeyboardInterrupt:
        raise SystemExit(130)
