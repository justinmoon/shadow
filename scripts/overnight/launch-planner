#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
PROMPT_PATH="$SCRIPT_DIR/planner-prompt.md"

project="boot"
mode="plan"
print_prompt=0
codex_bin="${CODEX_BIN:-codex}"
extra_note=""
codex_args=()

usage() {
  cat <<'EOF'
usage: scripts/overnight/launch-planner [options] [-- <codex args>]

Launch a dedicated Codex overnight planner session with the private planner
prompt injected. This does not install or expose an overnight repo skill.

Options:
  --project <id>      Dispatch project to inspect or run. Default: boot
  --mode <mode>       plan, launch, resume, or monitor. Default: plan
  --note <text>       Extra user instruction appended to the planner prompt
  --codex-bin <path>  Codex executable. Default: $CODEX_BIN or codex
  --print-prompt      Print the generated prompt instead of launching Codex
  -h, --help          Show this help

Examples:
  scripts/overnight/launch-planner --mode plan
  scripts/overnight/launch-planner --project boot --mode launch -- --model gpt-5.5
EOF
}

while (($#)); do
  case "$1" in
    --project)
      project="${2:?missing value for --project}"
      shift 2
      ;;
    --mode)
      mode="${2:?missing value for --mode}"
      shift 2
      ;;
    --note)
      extra_note="${2:?missing value for --note}"
      shift 2
      ;;
    --codex-bin)
      codex_bin="${2:?missing value for --codex-bin}"
      shift 2
      ;;
    --print-prompt)
      print_prompt=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      codex_args+=("$@")
      break
      ;;
    *)
      printf 'launch-planner: unknown argument: %s\n\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

case "$mode" in
  plan|launch|resume|monitor) ;;
  *)
    printf 'launch-planner: invalid --mode %s\n' "$mode" >&2
    exit 2
    ;;
esac

prompt="$(<"$PROMPT_PATH")"
prompt="${prompt//\{\{PROJECT\}\}/$project}"
prompt="${prompt//\{\{MODE\}\}/$mode}"

if [[ -n "$extra_note" ]]; then
  prompt+=$'\n\n## Extra User Instruction\n\n'
  prompt+="$extra_note"
fi

if ((print_prompt)); then
  printf '%s\n' "$prompt"
  exit 0
fi

exec "$codex_bin" "${codex_args[@]}" -C "$REPO_ROOT" "$prompt"
